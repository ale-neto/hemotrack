# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=sua_chave_jwt_super_secreta_minimo_32_caracteres
JWT_EXPIRES_IN=7d

# Encryption (API Keys dos usuários - deve ter exatamente 32 chars)
ENCRYPTION_KEY=32_caracteres_hex_para_criptografia

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hemotrack
DB_USER=hemotrack
DB_PASS=hemotrack_pass

# Upload
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:4200
